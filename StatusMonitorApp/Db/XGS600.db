record(mbbi, "$(P):ReadUnit"){
  field(DESC, "Read the Unit of Pressure")
  field(DTYP, "stream")
  field(INP, "@XGS600.proto readUnit $(PORT)")
  field(ZRVL, "1")
  field(ONVL, "Torr")
  field(ONVL, "2")
  field(ONST, "mbar")
  field(TWVL, "3")
  field(TWST, "Par")
  field(SCAN, "I/O Intr")
}

