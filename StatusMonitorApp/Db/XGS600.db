record(mbbo, "$(P):AssignPipe") {
    field(DESC,  "Allocate pipeline to sensor")
    field(DTYP,  "stream")
    field(OUT,   "@assignPipe.proto assignPipe $(PORT)")
    field(OMSL,  "supervisory")   
    # Enumerate tags (display name)
    field(ZRST,  "IMG100")    # VAL = 0
    field(ONST,  "IMG300")    # VAL = 1
    field(TWST,  "MBA100")    # VAL = 2
    field(THST,  "MBA200")    # VAL = 3
    field(FRST,  "563")       # VAL = 4
    field(FVST,  "564")       # VAL = 5
    field(SXST,  "571")       # VAL = 6
    field(SVST,  "572")       # VAL = 7
    field(EIST,  "UHV24")     # VAL = 8
    field(TVST,  "UHV24p")    # VAL = 9
    # Corresponding to the actual command value xx
    field(ZRVL,  "17")        # IMG100 -> 0x11 =17
    field(ONVL,  "19")        # IMG300 -> 0x13 =19
    field(TWVL,  "81")        # MBA100 -> 0x51 =81
    field(THVL,  "82")        # MBA200 -> 0x52 =82
    field(FRVL,  "99")        # 563 -> 0x63 =99
    field(FVVL,  "100")       # 564 -> 0x64 =100
    field(SXVL,  "113")       # 571 -> 0x71 =113
    field(SVVL,  "114")       # 572 -> 0x72 =114
    field(EIVL,  "128")       # UHV24 -> 0x80 =128
    field(TVVL,  "129")       # UHV24p -> 0x81 =129
    field(PREC,   "0")
}

record(mbbi, "$(P):ReadPipeType") {
    field(DESC,  "Read Sensor Pipe Type Input")
    field(DTYP,  "stream")
    field(OUT,   "@assignPipe.proto assignPipe $(PORT)")
    field(OMSL,  "supervisory")
    # Enumerate tags (display name)
    field(ZRST,  "IMG100")    # VAL = 0
    field(ONST,  "IMG300")    # VAL = 1
    field(TWST,  "MBA100")    # VAL = 2
    field(THST,  "MBA200")    # VAL = 3
    field(FRST,  "563")       # VAL = 4
    field(FVST,  "564")       # VAL = 5
    field(SXST,  "571")       # VAL = 6
    field(SVST,  "572")       # VAL = 7
    field(EIST,  "UHV24")     # VAL = 8
    field(TVST,  "UHV24p")    # VAL = 9
    # Corresponding to the actual command value xx
    field(ZRVL,  "17")        # IMG100 -> 0x11 =17
    field(ONVL,  "19")        # IMG300 -> 0x13 =19
    field(TWVL,  "81")        # MBA100 -> 0x51 =81
    field(THVL,  "82")        # MBA200 -> 0x52 =82
    field(FRVL,  "99")        # 563 -> 0x63 =99
    field(FVVL,  "100")       # 564 -> 0x64 =100
    field(SXVL,  "113")       # 571 -> 0x71 =113
    field(SVVL,  "114")       # 572 -> 0x72 =114
    field(EIVL,  "128")       # UHV24 -> 0x80 =128
    field(TVVL,  "129")       # UHV24p -> 0x81 =129
    field(SCAN,  "I/O Intr")
}

