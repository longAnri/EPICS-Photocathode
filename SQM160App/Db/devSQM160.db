########################################################################
###   Command D
###   Update
###   The active Film
######################################################################### 
record(ao, "$(P):activeFilm")
{
	field(DESC, "Update the active Film")
	field(DTYP,	"stream")
	field(OUT,	"@devSQM160.proto Active_Film() $(PORT)")
	field(DRVL,	"1")
	field(LOPR,	"1")
	field(DRVH,	"99")
	field(HOPR,	"99")
	field(VAL,	"1")
	field(FLNK,	"$(P):ApplyFilm")
}

