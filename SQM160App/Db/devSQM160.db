record(calcout, "$(P):ApplySys1")
{
    field(DESC, "Apply Sys1")

    field(INPA, "$(P):sTimeBase")
    field(INPB, "$(P):sSimMode")
    field(INPC, "$(P):sFreqMode")
    field(INPD, "$(P):sRateRes")
    field(INPE, "$(P):sRateFilter")
	field(INPF,	"$(P):sCrTool1")
	field(INPG,	"$(P):sCrTool2")
	field(INPH,	"$(P):sCrTool3")
	field(INPI,	"$(P):sCrTool4")
	field(INPJ,	"$(P):sCrTool5")
	field(INPK,	"$(P):sCrTool6")

    field(CALC, "0")
    field(DTYP, "stream")
    field(PINI, "YES")
    field(OUT, "@devSQM160.proto setSys1_Par $(PORT)")
}



