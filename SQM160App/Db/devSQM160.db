
#########################################################################
###   Command @ 
###   Query
###   Return the Filmware Version Number
######################################################################### 
record(ai,"$(P):Version"){
	field(DESC, "Get Version")
	field(DTYP, "stream")
	field(INP,  "@devSQM160.proto getVersion $(PORT)")
	field(PREC,	"2")
	field(SCAN, "10 second")
}


#########################################################################
###   Command A 
###   Query
###   Film Parameters
######################################################################### 
record(ao, "$(P):filmNumber"){
	field(DESC, "Set FilmNumber")
	field(LOPR, "1")
	field(HOPR, "99")
	field(DRVH,	"1")
	field(DRVL,	"99")
	field(VAL,	"1")
}

record(stringin, "$(P):gFilmName")
{
	field(DESC, "Read the Film Name")
	field(DTYP,	"stream")
	field(INP,	"@devSQM160.proto getFilmPar($(P)) $(PORT)")
	field(SCAN,	"1 second")
	field(FLNK,	"$(P):gDensity")
}

record(ai, "$(P):gFilmNumber")
{
	field(DESC, "Read the Film Number")
	field(LOPR,	"1")
	field(HOPR,	"99")
	field(FLNK,	"$(P):gDensity")
}

record(ai, "$(P):gDensity"){
	field(DESC, "Read Film Density")
	field(LOPR,	"0.50")
	field(HOPR,	"99.99")
	field(HIHI,	"99.00")
	field(HHSV,	"MAJOR")
	field(HIGH,	"98.00")
	field(HSV,	"MINOR")
	field(LOW,	"1.00")
	field(LSV,	"MINOR")
	field(LOLO,	"0.60")
	field(LLSV,	"MAJOR")
	field(PREC,	"2")
	field(EGU,	"g/cm^3")
	field(FLNK,	"$(P):gFilmTooling")	
}

