	field(HOPR,	"9.999")
	field(PREC,	"3")
	field(VAL,	"1.05")
	field(FLNK,	"$(P):ApplyFilm")	
}

record(ao, "$(P):sFinalThickness"){
	field(DESC, "Set Final Thickness")
	field(DRVL,	"0.000")
	field(LOPR,	"0.000")
	field(DRVH,	"9999.000")
	field(HOPR,	"9999.000")
	field(PREC,	"3")
	field(EGU,	"kA")
	field(VAL,	"1.525")
	field(FLNK,	"$(P):ApplyFilm")	
}

record(ao, "$(P):sThicknessSetpoint"){
	field(DESC, "Set Thickness Setpoint")
	field(DRVL,	"0.000")
	field(LOPR,	"0.000")
	field(DRVH,	"9999.000")
	field(HOPR,	"9999.000")
	field(EGU,	"kA")
	field(PREC,	"3")
	field(VAL,	"0.450")
