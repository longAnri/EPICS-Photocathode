record(mbboDirect, "$(P):sSensorAve"){
	field(DESC, "Set Sensor Average")
	field(VAL,	"1")
	field(FLNK,	"$(P):ApplyFilm")
}

record(calcout, "$(P):ApplyFilm")
{
    field(DESC, "Apply all film parameters")

#    field(INPA, "$(P):sFilmNumber")
	field(INPA,	"$(P):activeFilm")
#    field(INPB, "$(P):sFilmName CPP")
    field(INPC, "$(P):sDensity")
    field(INPD, "$(P):sFilmTooling")
    field(INPE, "$(P):sZ-Ratio")
	field(INPF,	"$(P):sFinalThickness")
	field(INPG,	"$(P):sThicknessSetpoint")
	field(INPH,	"$(P):sTimeSetpoint")
	field(INPJ,	"$(P):sSensorAve")

    field(CALC, "0")
    field(DTYP, "stream")
    field(PINI, "YES")
    field(OUT, "@devSQM160Test.proto setFilmPar($(P)) $(PORT)")
}


