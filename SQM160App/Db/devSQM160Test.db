#########################################################################
###   Command A 
###   Query
###   Film Parameters
######################################################################### 
record(ao, "$(P):filmNumber"){
	field(DESC, "Set FilmNumber")
	field(LOPR, "1")
	field(HOPR, "99")
	field(DRVH,	"1")
	field(DRVL,	"99")
	field(VAL,	"1")
}

record(stringin, "$(P):gFilmName")
{
	field(DESC, "Read the Film Name")
	field(DTYP,	"stream")
	field(INP,	"@devSQM160Test.proto getFilmPar($(P)) $(PORT)")
	field(SCAN,	"5 second")
	field(FLNK,	"$(P):gFilmNumber")
}

record(ai, "$(P):gFilmNumber")
{
	field(DESC, "Read the Film Number")
	field(LOPR,	"1")
	field(HOPR,	"99")
	field(FLNK,	"$(P):gDensity")
}

record(ai, "$(P):gDensity"){
	field(DESC, "Read Film Density")
	field(LOPR,	"0.50")
	field(HOPR,	"99.99")
	field(HIHI,	"99.00")
	field(HHSV,	"MAJOR")
	field(HIGH,	"98.00")
	field(HSV,	"MINOR")
	field(LOW,	"1.00")
	field(LSV,	"MINOR")
	field(LOLO,	"0.60")
	field(LLSV,	"MAJOR")
	field(PREC,	"2")
	field(EGU,	"g/cm^3")
	field(FLNK,	"$(P):gFilmTooling")	
}

record(ai, "$(P):gFilmTooling"){
	field(DESC, "Read Film Tooling")
	field(LOPR,	"10")
	field(HOPR,	"399")
	field(HIHI,	"390")
	field(HHSV,	"MAJOR")
	field(HIGH,	"385")
	field(HSV,	"MINOR")
	field(LOW,	"15")
	field(LSV,	"MINOR")
	field(LOLO,	"11")
	field(LLSV,	"MAJOR")
	field(EGU,	"%")
	field(FLNK,	"$(P):gZ-Ratio")	
}

record(ai, "$(P):gZ-Ratio"){
	field(DESC, "Read Z-Ratio")
	field(LOPR,	"0.1")
	field(HOPR,	"9.999")
	field(HIHI,	"9.999")
	field(HHSV,	"MAJOR")
	field(LOLO,	"0.1")
	field(LLSV,	"MAJOR")
	field(PREC,	"3")
	field(FLNK,	"$(P):gFinalThickness")	
}

record(ai, "$(P):gFinalThickness"){
	field(DESC, "Read Final Thickness")
	field(LOPR,	"0.000")
	field(HOPR,	"9999.000")
	field(HIHI,	"9990.000")
	field(HHSV,	"MAJOR")
	field(HIGH,	"9950.000")
	field(HSV,	"MINOR")
	field(LOW,	"20")
	field(LSV,	"MINOR")
	field(LOLO,	"10")
	field(LLSV,	"MAJOR")
	field(PREC,	"3")
	field(EGU,	"kA")
	field(FLNK,	"$(P):gThicknessSetpoint")	
}

record(ai, "$(P):gThicknessSetpoint"){
	field(DESC, "Read Thickness Setpoint")
	field(LOPR,	"0.000")
	field(HOPR,	"9999.000")
	field(PREC,	"3")
	field(EGU,	"kA")
	field(FLNK,	"$(P):gTimeSetpint.PROC")	
}

record(ai, "$(P):gTimeSetpoint"){
	field(DESC, "Read Time Setpoint")
	field(LOPR,	"0")
	field(HOPR,	"5999")
	field(EGU,	"s")
	field(FLNK,	"$(P):gSensorAve")	
}

record(mbbiDirect, "$(P):gSensorAve"){
	field(DESC, "Read Sensor Average")
}

#########################################################################
###   Command D
###   Update
###   The active Film
######################################################################### 
record(ao, "$(P):activeFilm")
{
    field(DESC, "Update the active Film")
    field(DTYP, "stream")
    field(OUT,  "@devSQM160.proto Active_Film() $(PORT)")
    field(DRVL, "1")
    field(LOPR, "1")
    field(DRVH, "99")
    field(HOPR, "99")
    field(VAL,  "1")
	field(FLNK, "$(P):ApplyFilm")
}

