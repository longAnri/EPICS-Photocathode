record(stringout,"$(P):sFilmName"){
	field(DESC, "Set Film Name")
	field(VAL,	"GOLD")
	field(FLNK,	"$(P):ApplyFilm")
}

record(ao, "$(P):sDensity"){
	field(DESC, "Set Film Density")
	field(DRVL,	"0.50")
	field(LOPR,	"0.50")
	field(DRVH,	"99.99")
	field(HOPR,	"99.99")
	field(VAL,	"6.23")
	field(PREC,	"2")
	field(EGU,	"g/cm^3")
	field(FLNK,	"$(P):ApplyFilm")	
}

