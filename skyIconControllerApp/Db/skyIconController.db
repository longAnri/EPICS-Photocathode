record(ai, "$(P)$(R):getVolt")
{
    field(DESC, "get volt")
    field(DTYP, "stream")
    field(INP,  "@skyIconController.proto getV() $(PORT)")
    field(EGU, "V")
	field(PREC,	"2")
    field(SCAN, "1 second")
}

