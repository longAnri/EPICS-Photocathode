record(ao, "$(P)$(R):SetOnValue")
{
    field(DESC, "Switch-On Value")
	field(PREC,	"4")
	field(VAL,	"5e-3")
    field(FLNK, "$(P)$(R):ApplySensor")
}

record(ao, "$(P)$(R):SetOffValue")
{
    field(DESC, "Switch-Off Value")
