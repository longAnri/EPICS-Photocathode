#
record(mbbo, "$(P)$(R):Channel")
{
    field(DESC, "Select Channel")
    field(ONVL, "1")
    field(ONST, "Channel 1")
    field(TWVL, "2")
    field(TWST, "Channel 3")
    field(THVL, "3")
    field(THST, "Channel 3")
    field(VAL, "3")
#    field(FLNK, "$(P)$(R):RPV")
}

record(mbbi, "$(P)$(R):Status")
{
    field(DESC, "The status of channel")
    field(DTYP, "stream")
    field(INP, "@devCombivac.proto readPressure($(P)$(R)) $(PORT)")
    field(ZRST, "OK")
    field(ONST, "BelowRange")
    field(TWST, "AboveRange")
    field(THST, "ErrLo")
    field(FRST, "ErrHi")
    field(FVST, "SensorOff")
    field(SXST, "HVon")
    field(SVST, "SensorErr")
    field(EIST, "NoSensor")
    field(NIST, "NoTrig")
    field(TEST, "ErrPi")
	field(ELST,	"DegasOK")
    field(SCAN, "1 second")
	field(FLNK,	"$(P)$(R):RPV")
}

record(ai, "$(P)$(R):RPV")
{
    field(DESC, "Read pressure")
	field(PREC,	"2")
	field(HIHI,	"5E-7")
	field(HHSV,	"MAJOR")
	field(HIGH,	"1E-7")
	field(HSV,	"MINOR")
	field(LOW,	"5E-10")
	field(LSV,	"MINOR")
	field(LOLO,	"1E-10")
	field(LLSV,	"MAJOR")
	field(EGU,	"Pa")
}
record(ai, "$(P)$(R):RVN")
{
    field(DESC, "the version number")
    field(DTYP, "stream")
    field(INP, "@devCombivac.proto readVersion $(PORT)")
	field(PREC,	"2")
    field(SCAN, "1 second")
}

record(bi, "$(P)$(R):RSS_SP1")
{
    field(DESC, "the status")
    field(DTYP, "stream")
    field(INP, "@devCombivac.proto readSwitch_Status($(P)$(R)) $(PORT)")
    field(ZNAM, "LOW")
    field(ONAM, "HIGH")
    field(SCAN, "1 second")
    field(FLNK, "$(P)$(R):RSS_SP2")
}

record(bi, "$(P)$(R):RSS_SP2")
{
    field(DESC, "the status")
    field(ZNAM, "LOW")
    field(ONAM, "HIGH")
}

record(bo, "$(P)$(R):SHV")
{
    field(DESC, "Setting HV on/off")
    field(DTYP, "stream")
    field(OUT, "@devCombivac.proto setHV $(PORT)")
    field(ZNAM, "OFF")
    field(ONAM, "ON")
	field(VAL,	"0")
}

record(bo, "$(P)$(R):SDG")
{
    field(DESC, "degas function")
    field(DTYP, "stream")
    field(OUT, "@devCombivac.proto setDegas() $(PORT)")
    field(ZNAM, "OFF")
    field(ONAM, "ON")
	field(VAL,	"0")
}

record(bo, "$(P)$(R):SKL")
{
    field(DESC, "keylock")
    field(DTYP, "stream")
    field(OUT, "@devCombivac.proto setLock() $(PORT)")
    field(ZNAM, "OFF")
    field(ONAM, "ON")
	field(VAL,	"0")
}

record(ao, "$(P)$(R):SAC")
{
    field(DESC, "Saving current configuration")
    field(DTYP, "stream")
    field(OUT, "@devCombivac.proto saveConfigure $(PORT)")
}

record(ai, "$(P)$(R):RSA")
{
    field(DESC, "Read address for RS485")
    field(DTYP, "stream")
    field(INP, "@devCombivac.proto readAddress $(PORT)")
    field(SCAN, "1 second")
}

record(ao, "$(P)$(R):SSA")
{
    field(DESC, "Setting adress for RS485")
    field(DTYP, "stream")
    field(OUT, "@devCombivac.proto setAddress $(PORT)")
}

record(mbbi, "$(P)$(R):RGP_Unit")
{
    field(DESC, "Read Unit")
    field(DTYP, "stream")
    field(INP, "@devCombivac.proto readSetting($(P)$(R)) $(PORT)")
    field(ZRVL, "0")
    field(ZRST, "mbar")
    field(ONVL, "1")
    field(ONST, "Pa")
    field(TWVL, "2")
    field(TWST, "Torr")
    field(SCAN, "1 second")
    field(FLNK, "$(P)$(R):RGP_Display_Number")
}


