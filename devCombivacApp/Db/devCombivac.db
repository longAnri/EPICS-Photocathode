record(mbbo, "$(P)$(R):Baudrate")
{
    field(DESC, "Select Baudrate")
    field(ZRVL, "0")
    field(ZRST, "9600")
    field(ONVL, "1")
    field(ONST, "19200")
    field(TWVL, "3")
    field(TWST, "38400")
	field(VAL,	"1")
    field(FLNK, "$(P)$(R):ApplySet")
}

record(bo, "$(P)$(R):Serial")
{
    field(DESC, "Select Serial")
    field(ZNAM, "RS232")
    field(ONAM, "RS485")
	field(VAL,	"0")
	field(FLNK,	"$(P)$(R):ApplySet")
}

record(calcout, "$(P)$(R):ApplySet")
{
    field(DESC, "Apply all channel settings")

    field(INPA, "$(P)$(R):Unit")
    field(INPB, "$(P)$(R):Display_Number")
    field(INPC, "$(P)$(R):Brightness")
    field(INPD, "$(P)$(R):Baudrate")
    field(INPE, "$(P)$(R):Serial")

    field(CALC, "0")
    field(DTYP, "stream")
#    field(PINI, "YES")
    field(OUT, "@devCombivac.proto setSetting $(PORT)")
}


record(ai, "$(P)$(R):RGC")
{
    field(DESC, "gas correction factor")
    field(DTYP, "stream")
    field(INP, "@devCombivac.proto readType $(PORT)")
	field(HIHI,	"7.80")
	field(HHSV,	"MAJOR")
	field(HIGH,	"7.50")
	field(HSV,	"MINOR")
	field(LOW,	"0.80")
	field(LSV,	"MINOR")
	field(LOLO,	"0.50")
	field(LLSV,	"MAJOR")
    field(LOPR, "0.20")
    field(HOPR, "8.00")
	field(PREC,	"2")
    field(SCAN, "1 second")
	field(PINI,	"YES")
	field(FLNK,	"$(P)$(R):syncSGC")
}

record(calcout, "$(P)$(R):syncSGC")
{
    field(INPA, "$(P)$(R):RGC")
    field(CALC, "A")
    field(OUT,  "$(P)$(R):SGC")
}


record(ao, "$(P)$(R):SGC")
{
    field(DESC, "gas correction factor")
    field(DTYP, "stream")
    field(OUT, "@devCombivac.proto setType $(PORT)")
    field(LOPR, "0.20")
    field(HOPR, "8.00")
    field(DRVL, "0.20")
    field(DRVH, "8.00")
	field(PREC,	"2")
}


