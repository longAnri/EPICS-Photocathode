	field(FLNK,	"$(P)$(R):ApplySensor")
}

record(calcout, "$(P)$(R):ApplySensor")
{
    field(DESC, "Apply all Sensors")
    field(INPA, "$(P)$(R):SetOnType")
    field(INPB, "$(P)$(R):SetOffType")
    field(INPC, "$(P)$(R):SetOnValue")
    field(INPD, "$(P)$(R):SetOffValue")
    field(CALC, "0")
    field(DTYP, "stream")
#    field(PINI, "YES")
    field(OUT, "@devCombivac.proto setSensor $(PORT)")
}

