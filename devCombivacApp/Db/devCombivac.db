record(mbbo, "$(P)$(R):Th_Channel")
{
    field(DESC, "Select Channel")
    field(ONVL, "1")
    field(ONST, "Channel 1")
    field(TWVL, "2")
    field(TWST, "Channel 3")
    field(THVL, "3")
    field(THST, "Channel 3")
    field(VAL, "3")
    field(FLNK, "$(P)$(R):ApplyThresh")
}

record(ao, "$(P)$(R):SSP_SP1_LOW")
{
    field(DESC, "SP1 Low")
	field(PREC,	"4")
	field(VAL,	"2.1e-8")
    field(FLNK, "$(P)$(R):ApplyThresh")
}


record(ao, "$(P)$(R):SSP_SP1_HIGH")
{
    field(DESC, "SP1 High")
	field(PREC,	"4")
	field(VAL,	"2.4e-8")
    field(FLNK, "$(P)$(R):ApplyThresh")
}

record(ao, "$(P)$(R):SSP_SP2_LOW")
{
    field(DESC, "SP2 Low")
	field(PREC,	"4")
	field(VAL,	"1e-8")
    field(FLNK, "$(P)$(R):ApplyThresh")
}

record(ai, "$(P)$(R):SSP_SP2_HIGH")
{
    field(DESC, "SP2 HIGH")
	field(PREC,	"4")
	field(VAL,	"1.1e-8")
	field(FLNK,	"$(P)$(R):ApplyThresh")
}

record(calcout, "$(P)$(R):ApplyThresh")
{
    field(DESC, "Apply all channel thresholds")

    field(INPA, "$(P)$(R):Th_Channel")
    field(INPB, "$(P)$(R):SSP_SP1_LOW")
    field(INPC, "$(P)$(R):SSP_SP1_HIGH")
    field(INPD, "$(P)$(R):SSP_SP2_LOW")
    field(INPE, "$(P)$(R):SSP_SP2_HIGH")
    field(CALC, "0")
    field(DTYP, "stream")
#    field(PINI, "YES")
    field(OUT, "@devCombivac.proto setThresholds $(PORT)")
}
