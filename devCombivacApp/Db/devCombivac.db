record(mbbo, "$(P)$(R):SetOnType")
{
    field(DESC, "Sensor Swith-On Type Channel")
    field(ZRVL, "0")
    field(ZRST, "Manual")
    field(ONVL, "1")
    field(ONST, "External")
    field(TWVL, "2")
    field(TWST, "n.a")
    field(THVL, "3")
    field(THST, "Through channel 1")
    field(FRVL, "4")
    field(FRST, "Through channel 2")
    field(SCAN, "1 second")
	field(VAL,	"0")
    field(FLNK, "$(P)$(R):ApplySensor")
}


record(mbbo, "$(P)$(R):SetOffType")
{
    field(DESC, "Sensor Switch-Off Type Channel")
    field(ZRVL, "0")
    field(ZRST, "Manual")
    field(ONVL, "1")
    field(ONST, "External")
    field(TWVL, "2")
    field(TWST, "Self-monitoring")
