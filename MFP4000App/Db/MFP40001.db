record(mbbi, "$(P)$(R):gInst")
{
    field(DESC, "Current Inst")
    field(DTYP, "stream")
    field(INP,  "@MFP4000.proto getINST($(P)$(R)) $(PORT)")
    field(ZRST, "CH1")
    field(ONST, "CH2")
    field(TWST, "CH3")
    field(THST, "CH4")
    field(FRST, "CH5")
    field(SCAN, "1 second")
}

record(mbbo, "$(P)$(R):sInst")
{
    field(DESC, "Current Inst")
    field(DTYP, "stream")
    field(OUT,  "@MFP4000.proto setINST($(P)$(R)) $(PORT)")
    field(ZRVL, "0")
    field(ZRST, "1")
    field(ONVL, "1")
    field(ONST, "2")
    field(TWVL, "2")
    field(TWST, "3")
    field(THVL, "3")
    field(THST, "4")
    field(FRVL, "4")
    field(FRST, "5")
	field(VAL,	"0")
}

