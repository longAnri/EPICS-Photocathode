# Read Command
record(bi, "$(P)$(R):getBEEP")
{
    field(DESC, "Power beep status")
    field(DTYP, "stream")
    field(INP,  "@MFP4000.proto getBEEP() $(PORT)")
    field(ZNAM, "OFF")
    field(ONAM, "ON")
    field(SCAN, "1 second")
}

record(bo, "$(P)$(R):setBEEP")
{
    field(DESC, "Power beep status")
    field(DTYP, "stream")
    field(OUT,  "@MFP4000.proto setBEEP() $(PORT)")
    field(ZNAM, "OFF")
    field(ONAM, "ON")
    field(VAL, "1")
}

record(ai, "$(P)$(R):gVolt1")
{
    field(DESC, "1 Channels")
    field(DTYP, "stream")
    field(INP,  "@MFP4000.proto getAPVOLT($(P)$(R)) $(PORT)")
    field(EGU,  "V")
	field(PREC,	"3")
    field(SCAN, "1 second")
	field(PINI,	"YES")
	field(FLNK,	"$(P)$(R):syncVolt1")
    field(FLNK, "$(P)$(R):gVolt2")
}

record(calcout, "$(P)$(R):syncVolt1")
{
    field(INPA, "$(P)$(R):gVolt1.VAL")
    field(CALC, "A")
    field(OUT,  "$(P)$(R):sVolt1.VAL PP")
}


