record(calcout, "$(P)$(R):ApplyVolt")
{
    field(DESC, "Apply all channel voltages")

    field(INPA, "$(P)$(R):sVolt1")
    field(INPB, "$(P)$(R):sVolt2")
    field(INPC, "$(P)$(R):sVolt3")
    field(INPD, "$(P)$(R):sVolt4")
    field(INPE, "$(P)$(R):sVolt5")

    field(CALC, "0")
    field(DTYP, "stream")
    field(OUT, "@MFP4000.proto setAPVOLT $(PORT)")
}

